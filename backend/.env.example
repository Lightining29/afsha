PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/glowora
JWT_SECRET=your-jwt-secret-change-in-production
CLIENT_URL=http://localhost:3000

# Razorpay (required — checkout fails if missing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email receipts (optional — logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Glowora" <noreply@glowora.com>
